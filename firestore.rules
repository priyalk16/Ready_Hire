rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Helpers ---

    function isValidUser(data) {
      return data.uid == request.auth.uid 
             && data.email is string && data.email.size() <= 256
             && (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 128))
             && data.createdAt == request.time;
    }

    function isValidCareerDiscovery(data) {
      return data.userId == request.auth.uid
             && data.report is map
             && data.createdAt == request.time;
    }

    function isValidAssessment(data) {
      return data.userId == request.auth.uid
             && data.createdAt == request.time;
    }

    // --- Collection Routes ---

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) 
                    && incoming().uid == existing().uid
                    && incoming().createdAt == existing().createdAt
                    && incoming().updatedAt == request.time;

      match /careerDiscovery/{docId} {
        allow get: if isOwner(userId);
        allow write: if isOwner(userId) && isValidCareerDiscovery(incoming());
      }

      match /prepAssessments/{assessmentId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(assessmentId) && isValidAssessment(incoming());
        allow update: if isOwner(userId) 
                      && incoming().userId == existing().userId
                      && incoming().updatedAt == request.time;
      }
    }
  }
}
